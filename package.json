{
  "name": "typescript-to-gdscript",
  "version": "0.1.0",
  "description": "Convert TypeScript to GDScript for Godot game engine",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./eslint": "./dist/eslint/plugin.js"
  },
  "packageManager": "yarn@1.22.22",
  "typesVersions": {
    "*": {
      "typings": [
        "typings/index.d.ts"
      ],
      "typings/4.7": [
        "typings/4.7/index.d.ts"
      ],
      "typings/latest": [
        "typings/latest/index.d.ts"
      ]
    }
  },
  "bin": {
    "tstogd": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "tsc --noEmit",
    "generate:ast-types": "tsx src/parser/gdscript/generate-types.ts",
    "generate:godot-typings": "tsx src/cli/index.ts generate-typings --docs-dir vendor/godot/doc/classes --typings-dir typings --set-latest",
    "set-latest": "tsx src/cli/index.ts set-latest"
  },
  "prettier": {
    "trailingComma": "all",
    "tabWidth": 2,
    "semi": true,
    "singleQuote": true
  },
  "keywords": [
    "typescript",
    "gdscript",
    "godot",
    "converter",
    "transpiler"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "chokidar": "^4.0.0",
    "commander": "^13.0.0",
    "minimatch": "^10.2.4",
    "source-map": "^0.7.4",
    "tree-sitter": "^0.22.0",
    "tree-sitter-gdscript": "^6.1.0",
    "typescript": "^5.9.0"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0"
  },
  "peerDependenciesMeta": {
    "eslint": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.0.3",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "vitest": "^3.0.0"
  }
}
