{
  "name": "typescript-to-gdscript",
  "version": "0.1.0",
  "description": "Convert TypeScript to GDScript for Godot game engine",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./ts-plugin": "./dist/ts-plugin/index.js"
  },
  "files": [
    "dist",
    "ts-plugin",
    "typings",
    "typings-overrides"
  ],
  "packageManager": "yarn@1.22.22",
  "typesVersions": {
    "*": {
      "typings": [
        "typings/index.d.ts"
      ]
    }
  },
  "bin": {
    "tstogd": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "tsc --noEmit",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "prepublishOnly": "yarn build",
    "release": "npm publish && git push --follow-tags",
    "release:patch": "npm version patch && npm run release",
    "release:minor": "npm version minor && npm run release",
    "release:major": "npm version major && npm run release",
    "generate:ast-types": "dts-tree-sitter tree-sitter-gdscript > src/parser/gdscript/types.ts && node scripts/fix-tree-sitter-types.js src/parser/gdscript/types.ts",
    "generate:resource-ast-types": "dts-tree-sitter tree-sitter-godot-resource > src/parser/godot-resource/types.ts && node scripts/fix-tree-sitter-types.js src/parser/godot-resource/types.ts",
    "generate:godot-typings": "tsx src/cli/index.ts generate-gdscript-global-typings --output-dir typings --docs-dir vendor/godot/doc/classes vendor/godot/modules/gdscript/doc_classes",
    "test:tstogd": "vitest run tests/converter/ts-to-gd.test.ts",
    "test:gdtots": "vitest run tests/converter/gd-to-ts.test.ts",
    "test:diag": "vitest run tests/converter/converter-diag.test.ts",
    "test:ts-plugin": "vitest run tests/ts-plugin/ts-plugin.test.ts",
    "test:scene-typings": "vitest run tests/typings/scene-typings.test.ts",
    "test:type-checks": "vitest run tests/typings/type-checks.test.ts",
    "test:class-typings": "vitest run tests/typings/class-typings.test.ts",
    "test:godot-docs": "vitest run tests/typings/godot-docs.test.ts",
    "test:godot-registry": "vitest run tests/typings/godot-registry.test.ts",
    "test:godot-validate": "vitest run tests/typings/godot-validate.test.ts",
    "test:sourcemap": "vitest run tests/typings/ts-to-gd-sourcemap.test.ts",
    "test:gd-registry": "vitest run tests/typings/gd-to-ts-registry.test.ts",
    "test:typecheck": "vitest run tests/typecheck.test.ts",
    "test:cli": "vitest run tests/cli/cli.test.ts",
    "prepare": "husky"
  },
  "prettier": {
    "trailingComma": "all",
    "tabWidth": 2,
    "semi": true,
    "singleQuote": true
  },
  "lint-staged": {
    "*": "prettier --write --ignore-unknown"
  },
  "keywords": [
    "typescript",
    "gdscript",
    "godot",
    "converter",
    "transpiler"
  ],
  "license": "MIT",
  "author": "nnn3d",
  "homepage": "https://github.com/nnn3d/typescript-to-gdscript#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nnn3d/typescript-to-gdscript.git"
  },
  "bugs": {
    "url": "https://github.com/nnn3d/typescript-to-gdscript/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "chokidar": "^4.0.0",
    "commander": "^13.0.0",
    "glob": "^13.0.6",
    "minimatch": "^10.2.4",
    "source-map": "^0.7.4",
    "tree-sitter": "^0.22.0",
    "tree-sitter-gdscript": "^6.1.0",
    "tree-sitter-godot-resource": "^0.7.0"
  },
  "peerDependencies": {
    "typescript": ">=5.5.0"
  },
  "devDependencies": {
    "@asgerf/dts-tree-sitter": "^0.21.0",
    "@types/glob": "^9.0.0",
    "@types/node": "^22.0.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0",
    "vitest": "^3.0.0"
  }
}
