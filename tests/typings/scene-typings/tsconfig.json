{
  "compilerOptions": {
    "target": "esnext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noLib": true,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": false,
    "types": []
  },
  "include": [
    "../../../typings",
    "./*.ts",
    "./**/*.ts",
    "./**/*.d.ts"
  ],
  "exclude": [
    "addons",
    "types/addons"
  ]
}
